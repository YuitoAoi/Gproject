{
  "semi": true,
  "singleQuote": false,
  "tabWidth": 4,
  "useTabs": false,
  "trailingComma": "all",
  "printWidth": 100,
  "endOfLine": "lf",
  "bracketSpacing": true,
  "arrowParens": "always",
  "overrides": [
    {
      "files": ["*.json", "*.jsonc"],
      "options": { "tabWidth": 2 }
    },
    {
      "files": ["*.md"],
      "options": {
        "proseWrap": "preserve",
        "tabWidth": 2
      }
    },
    {
      "files": ["*.yaml", "*.yml"],
      "options": { "tabWidth": 2, "singleQuote": true }
    }
  ]
}
